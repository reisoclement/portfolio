---
// Static CR + mustache brand mark for the website header.
// Paths are copied (not animated) from
// projects/watermark-logo/src/WatermarkLogo.tsx so the website mark stays
// visually identical to the watermark used in the videos.
//
// Composition mirrors the video watermark:
//   - CR monogram on top (with a hollow R via fill-rule="evenodd")
//   - Mustache below, curling under the CR
//
// Hover: the mustache wobbles (small rotation up/down), echoing the tip
// rotation in the animated watermark.

interface Props {
  size?: number;
  color?: string;
  ariaLabel?: string;
}

const { size = 36, color = 'currentColor', ariaLabel } = Astro.props;

