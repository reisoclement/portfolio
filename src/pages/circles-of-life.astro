---
import Base from '../layouts/Base.astro';
import InteractiveViewer from '../components/circles-of-life/InteractiveViewer';

const base = import.meta.env.BASE_URL;
const videoSrc = `${base}animations/circles-of-life/circles-of-life.mp4`;
---
<Base title="Circles of Life — Notebook">
  <section class="page container">
    <header class="page__header">
      <p class="page__eyebrow mono">Animation · 01</p>
      <h1 class="page__title">Circles of life</h1>
      <p class="page__lede prose">
        Concentric circles of responsibility. You earn the right to influence the next ring
        only by mastering the inner one — yet most people invert it, trying to fix the outside
        while the centre stays unfinished.
      </p>
    </header>

    <div class="tabs" role="tablist" aria-label="Playback mode">
      <button type="button" class="tab is-active" data-tab="video" role="tab" aria-selected="true" aria-controls="panel-video">
        Video
      </button>
      <button type="button" class="tab" data-tab="interactive" role="tab" aria-selected="false" aria-controls="panel-interactive">
        Interactive
      </button>
    </div>

    <div id="panel-video" class="panel is-active" role="tabpanel" aria-labelledby="tab-video">
      <div class="video-frame">
        <video controls preload="metadata" playsinline>
          <source src={videoSrc} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
      <p class="panel__caption muted">
        Press play. Around 70 seconds. Best with sound off — it's a silent piece for now.
      </p>
    </div>

    <div id="panel-interactive" class="panel" role="tabpanel" aria-labelledby="tab-interactive" hidden>
      <InteractiveViewer client:visible />
      <p class="panel__caption muted">
        One scene per press. Use this version when you want to talk over each beat — for a
        presentation, a discussion, or just to take it slowly.
      </p>
    </div>
  </section>
</Base>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const panels = document.querySelectorAll<HTMLElement>('.panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.id === `panel-${target}`;
        p.classList.toggle('is-active', active);
        if (active) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
    });
  });
</script>

<style>
  .page {
    padding-block: var(--space-8) var(--space-12);
  }
  .page__header {
    margin-bottom: var(--space-6);
  }
  .page__eyebrow {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .page__title {
    margin-bottom: var(--space-3);
  }
  .page__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    max-width: 60ch;
  }

  .tabs {
    display: inline-flex;
    gap: 0.4rem;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0;
  }
  .tab {
    font: inherit;
    padding: 0.5rem 1.1rem;
    border: 0;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .tab:hover { color: var(--color-text); }
  .tab.is-active {
    color: var(--color-text);
    border-bottom-color: #ffd166;
  }

  .panel {
    display: none;
  }
  .panel.is-active {
    display: block;
  }
  .panel__caption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    text-align: center;
  }

  .video-frame {
    border-radius: 12px;
    overflow: hidden;
    background: #05060a;
  }
  .video-frame video {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
</Base>
