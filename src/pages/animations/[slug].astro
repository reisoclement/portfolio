---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('animations', ({ data }) => !data.draft);
  const sorted = entries.sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return b.data.date.getTime() - a.data.date.getTime();
  });

  return sorted.map((entry, idx) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: sorted[idx - 1] ?? null,
      next: sorted[idx + 1] ?? null,
    },
  }));
}

interface Props {
  entry: CollectionEntry<'animations'>;
  prev: CollectionEntry<'animations'> | null;
  next: CollectionEntry<'animations'> | null;
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, duration, videoUrl, posterImage, specPath, tags } = entry.data;

const base = import.meta.env.BASE_URL;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const isoDate = date.toISOString();

// Convert "mm:ss" → ISO 8601 duration "PT0M42S" for schema.org
const [mm, ss] = duration.split(':').map(Number);
const isoDuration = `PT${mm || 0}M${ss || 0}S`;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: title,
  description,
  uploadDate: isoDate,
  duration: isoDuration,
  contentUrl: videoUrl,
  thumbnailUrl: posterImage ? new URL(`/portfolio/animations/${entry.slug}/${posterImage.replace(/^\.\//, '')}`, Astro.site).href : undefined,
  embedUrl: pageUrl,
};
---
<Base title={`${title} — Notebook`} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} slot="head" />

  <article class="animation container">
    <header class="animation__header">
      <p class="animation__eyebrow mono">
        <a href={`${base}`}>← Notebook</a>
      </p>
      <h1>{title}</h1>
      <p class="animation__lede">{description}</p>
    </header>

    <div class="animation__player">
      <video
        src={videoUrl}
        poster={posterImage ? `${base}animations/${entry.slug}/${posterImage.replace(/^\.\//, '')}` : undefined}
        controls
        playsinline
        preload="metadata"
      ></video>
    </div>

    <div class="animation__body prose">
      <Content />
    </div>

    <footer class="animation__meta">
      <dl>
        <div><dt>Published</dt><dd><time datetime={isoDate}>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></dd></div>
        <div><dt>Duration</dt><dd>{duration}</dd></div>
        {tags.length > 0 && (
          <div><dt>Tags</dt><dd>{tags.join(' · ')}</dd></div>
        )}
        {specPath && (
          <div><dt>Source</dt><dd><a href={`https://github.com/reisoclement/portfolio/blob/main/${specPath}`}>{specPath}</a></dd></div>
        )}
      </dl>

      <nav class="animation__nav" aria-label="Adjacent animations">
        {prev && <a class="animation__nav-link" href={`${base}animations/${prev.slug}/`}>← {prev.data.title}</a>}
        {next && <a class="animation__nav-link animation__nav-link--right" href={`${base}animations/${next.slug}/`}>{next.data.title} →</a>}
      </nav>
    </footer>
  </article>
</Base>

<style>
  .animation {
    padding-block: var(--space-8) var(--space-12);
  }
  .animation__header {
    max-width: var(--max-prose);
    margin-bottom: var(--space-6);
  }
  .animation__eyebrow {
    margin-bottom: var(--space-3);
  }
  .animation__eyebrow a {
    color: var(--color-text-muted);
    border-bottom: none;
  }
  .animation__eyebrow a:hover {
    color: var(--color-text);
  }
  .animation__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
    line-height: var(--leading-snug);
  }
  .animation__player {
    margin-bottom: var(--space-6);
    background: #000;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }
  .animation__player video {
    width: 100%;
    height: 100%;
    display: block;
  }
  .animation__body {
    margin-bottom: var(--space-8);
  }
  .animation__meta {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    max-width: var(--max-prose);
  }
  .animation__meta dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-1) var(--space-4);
    margin: 0 0 var(--space-6);
    font-size: var(--text-sm);
  }
  .animation__meta dl > div {
    display: contents;
  }
  .animation__meta dt {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding-top: 0.15em;
  }
  .animation__meta dd {
    margin: 0;
  }
  .animation__nav {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .animation__nav-link {
    color: var(--color-text-muted);
    border-bottom: none;
    font-size: var(--text-sm);
  }
  .animation__nav-link:hover {
    color: var(--color-text);
  }
  .animation__nav-link--right {
    margin-left: auto;
    text-align: right;
  }
</style>
