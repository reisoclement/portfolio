---
import Base from '../../layouts/Base.astro';
import InteractiveViewer from '../../components/animated-resume/InteractiveViewer';
import { isLocale, type Locale } from '../../i18n';
import {
  RESUME_LOCALES,
  RESUME_LOCALE_LABELS,
  isResumeLocale,
  getResumeStrings,
  type ResumeLocale,
} from '../../i18n/resume-locales';

export async function getStaticPaths() {
  return RESUME_LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isResumeLocale(lang)) throw new Error(`unsupported resume locale: ${lang}`);
const locale: ResumeLocale = lang;
const t = getResumeStrings(locale);

// The Base layout requires a site-wide Locale for nav/footer rendering.
// For zh (resume-only), fall back to English chrome.
const siteLocale: Locale = isLocale(locale) ? locale : 'en';

const base = import.meta.env.BASE_URL;
const videoSrc = `${base}animations/animated-resume/${locale}/animated-resume.mp4`;

// Resume-language switcher links: each option points to /<lang>/resume/.
const switcherLinks = RESUME_LOCALES.map((l) => ({
  locale: l,
  label: RESUME_LOCALE_LABELS[l],
  href: `${base}${l}/resume/`,
  active: l === locale,
}));
---
<Base locale={siteLocale} title={t.title} description={t.description}>
  <section class="page container">
    <header class="page__header">
      <p class="page__eyebrow mono">{t.eyebrow}</p>
      <h1 class="page__title">{t.heading}</h1>
      <p class="page__lede prose">{t.lede}</p>
    </header>

    <nav class="resume-langs" aria-label={t.resumeLanguageLabel}>
      <span class="resume-langs__label mono">{t.resumeLanguageLabel}</span>
      <ul>
        {switcherLinks.map((l) => (
          <li>
            <a
              href={l.href}
              class={l.active ? 'is-active' : ''}
              aria-current={l.active ? 'page' : undefined}
              lang={l.locale === 'zh' ? 'zh-CN' : l.locale}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="tabs" role="tablist" aria-label={t.tabs.ariaLabel}>
      <button type="button" class="tab is-active" data-tab="video" role="tab" aria-selected="true" aria-controls="panel-video">
        {t.tabs.video}
      </button>
      <button type="button" class="tab" data-tab="interactive" role="tab" aria-selected="false" aria-controls="panel-interactive">
        {t.tabs.interactive}
      </button>
    </div>

    <div id="panel-video" class="panel is-active" role="tabpanel" aria-labelledby="tab-video">
      <div class="video-frame">
        <video controls preload="metadata" playsinline>
          <source src={videoSrc} type="video/mp4" />
          {t.videoFallback}
        </video>
      </div>
      <p class="panel__caption muted">{t.videoCaption}</p>
    </div>

    <div id="panel-interactive" class="panel" role="tabpanel" aria-labelledby="tab-interactive" hidden>
      <InteractiveViewer client:visible locale={locale} />
      <p class="panel__caption muted">{t.interactiveCaption}</p>
    </div>
  </section>
</Base>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const panels = document.querySelectorAll<HTMLElement>('.panel');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;
      tabs.forEach((t) => {
        const active = t === tab;
        t.classList.toggle('is-active', active);
        t.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.id === `panel-${target}`;
        p.classList.toggle('is-active', active);
        if (active) {
          p.removeAttribute('hidden');
        } else {
          p.setAttribute('hidden', '');
        }
      });
    });
  });
</script>

<style>
  .page {
    padding-block: var(--space-8) var(--space-12);
  }
  .page__header {
    margin-bottom: var(--space-5);
  }
  .page__eyebrow {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .page__title {
    margin-bottom: var(--space-3);
  }
  .page__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    max-width: 60ch;
  }

  .resume-langs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1rem;
    margin-bottom: var(--space-4);
  }
  .resume-langs__label {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .resume-langs ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .resume-langs a {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: 1.2;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .resume-langs a:hover {
    color: var(--color-text);
    border-color: #e94f7c;
  }
  .resume-langs a.is-active {
    color: #0c1f33;
    background: #e94f7c;
    border-color: #e94f7c;
    font-weight: 600;
  }

  .tabs {
    display: inline-flex;
    gap: 0.4rem;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0;
  }
  .tab {
    font: inherit;
    padding: 0.5rem 1.1rem;
    border: 0;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .tab:hover { color: var(--color-text); }
  .tab.is-active {
    color: var(--color-text);
    border-bottom-color: #e94f7c;
  }

  .panel {
    display: none;
  }
  .panel.is-active {
    display: block;
  }
  .panel__caption {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    text-align: center;
  }

  .video-frame {
    border-radius: 12px;
    overflow: hidden;
    background: #0c1f33;
  }
  .video-frame video {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
