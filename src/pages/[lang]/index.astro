---
import Base from '../../layouts/Base.astro';
import { LOCALES, getT, isLocale, localeUrl, type Locale } from '../../i18n';

export async function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
if (!isLocale(lang)) throw new Error(`unsupported locale: ${lang}`);
const locale: Locale = lang;
const t = getT(locale);
const base = import.meta.env.BASE_URL;
const circlesHref = localeUrl(base, locale, 'circles-of-life');
const resumeHref = localeUrl(base, locale, 'resume');
const buildAgentsHref = localeUrl(base, locale, 'build-agents');
const whenToUseAiHref = localeUrl(base, locale, 'when-to-use-ai');
---
<Base locale={locale} title={t.home.title} description={t.home.description}>
  <section class="hero container">
    <p class="hero__eyebrow mono">{t.home.eyebrow}</p>
    <h1 class="hero__title">
      {t.home.headlineLine1}<br />{t.home.headlineLine2}
    </h1>
    <p class="hero__lede prose">
      {t.home.lede}
    </p>
  </section>

  <section class="intro container">
    <div class="prose">
      <h2>{t.home.whatYouFindHeading}</h2>
      <p>{t.home.whatYouFindParagraph}</p>
      <p set:html={t.home.builtWithParagraphHtml} />

      <h2>{t.home.currentlyHeading}</h2>
      <ul class="muted">
        <li>
          <a href={resumeHref}>{t.resume.heading}</a>
          — {t.resume.summaryShort}
        </li>
        <li>
          <a href={circlesHref}>{t.circlesOfLife.heading}</a>
          — {t.circlesOfLife.summaryShort}
        </li>
        <li>
          <a href={buildAgentsHref}>{t.buildAgents.heading}</a>
          — {t.buildAgents.summaryShort}
        </li>
        <li>
          <a href={whenToUseAiHref}>{t.whenToUseAi.heading}</a>
          — {t.whenToUseAi.summaryShort}
        </li>
      </ul>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding-block: var(--space-12) var(--space-8);
  }
  .hero__eyebrow {
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
  }
  .hero__title {
    margin-bottom: var(--space-4);
    max-width: 16ch;
  }
  .hero__lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }
  .intro {
    padding-block: var(--space-4) var(--space-8);
  }
  .intro h2 {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }
  .intro h2:first-child {
    margin-top: 0;
  }
</style>
